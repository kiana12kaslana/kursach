<Page x:Class="kursach.Pages.RegistationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kursach.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="400"
      Title="RegistationPage">

    <Grid Background="Black">
        <Border Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="20" Background="Wheat"  MaxWidth="500" >
            <StackPanel >
                <TextBlock Text="Регистрация" Background="Wheat" Margin="10, 10, 10, 10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Логин:" Background="Wheat" Margin="10, 10, 10, 10"/>
                    <TextBox x:Name="LoginTB"  Width="150" Margin="0, 10, 10, 10" MaxLength="30" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                    <TextBlock Text="Пароль:" Background="Wheat" Margin="10, 10, 10, 10" />
                    <TextBox x:Name="PasswordTB" Width="150" Margin="0, 10, 10, 10" MaxLength="30" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Email:" Background="Wheat" Margin="10, 10, 10, 10"/>
                    <TextBox x:Name="EmailTB" Width="150" Margin="0, 10, 10, 10" MaxLength="30" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,10,0">
                    <Button x:Name="BackBtn" Content="Возвращение" Background="White" Margin="0,0,15,0" HorizontalAlignment="Left" Click="BackBtn_Click"/>
                    <Button x:Name="Regitr" Content="Зарегестрироваться" Background="White" Margin="0,0,10,0" HorizontalAlignment="Right" Click="Regitr_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

<Page x:Class="kursach.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kursach.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="Black">
        <Border Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="200" Margin="15" Background="Wheat" MaxWidth="500" CornerRadius="20" >
            <StackPanel >
                <TextBlock Text="Ведите логин и пароль" Margin="10, 10, 10, 10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Логин:" Margin="10, 10, 10, 10"/>
                    <TextBox x:Name="LoginTB" Width="150" Margin="0, 10, 10, 10" MaxLength="30"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                    <TextBlock Text="Пароль:" Margin="10, 10, 10, 10" />
                    <TextBox x:Name="PasswordTB" Width="150" Margin="0, 10, 10, 10" MaxLength="30"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,10,0">
                    <Button x:Name="BackBtn" Content="Возвращение" HorizontalAlignment="Left" Margin="0,0,70,0" Click="BackBtn_Click"/>
                    <Button x:Name="EnterBtn" Content="Вход" HorizontalAlignment="Right" Margin="0,0,60,0" Click="EnterBtn_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

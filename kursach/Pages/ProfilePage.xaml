<Page x:Class="kursach.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kursach.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">
    <Grid Background="Black">
        <Border Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="200" Margin="15" Background="Wheat" MaxWidth="500" CornerRadius="20" >
            <StackPanel >
                <TextBlock Text="Ваш профиль" Margin="10, 10, 10, 10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Ваш логин:" Margin="10, 10, 10, 10"/>
                    <TextBlock x:Name="LoginTB" Width="150" Margin="0, 10, 10, 10" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock  Text="Ваш Email:" Margin="10, 10, 10, 10"/>
                    <TextBlock x:Name="EmailTB"  Width="150"  Margin="0, 10, 10, 10"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,10,0">
                    <Button x:Name="BackBtn" Content="Возвращение" HorizontalAlignment="Left" Margin="0,0,70,0" Click="BackBtn_Click" />
                    <Button Content="Выйти из аккаунта" HorizontalAlignment="Right" x:Name="GoHome" Click="GoHome_Click"  />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

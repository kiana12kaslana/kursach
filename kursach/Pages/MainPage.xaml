<Page x:Class="kursach.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:kursach.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Главное меню">

    <Grid Background="Black" >
        <Border MinWidth="200" Margin="15" Background="Wheat" VerticalAlignment="Center" Padding="30" MaxWidth="500" CornerRadius="20" >
            <StackPanel>
                <TextBlock Text="Добро пожаловать!" FontSize="30" FontWeight="Bold" Margin="0,0,0,20"></TextBlock>
                <Grid Margin="0,0,0,20">
                    <Button x:Name="RegBtn" HorizontalAlignment="Left" Content="Регистрация" Click="RegBtn_Click"></Button>
                    <Button x:Name="LoginBtn" HorizontalAlignment="Left" Content="Войти" Click="LoginBtn_Click" Height="20" Margin="403,0,0,0" VerticalAlignment="Top" ></Button>
                </Grid>
            </StackPanel>

        </Border>
    </Grid>
</Page>
